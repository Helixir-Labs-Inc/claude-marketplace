# Helixir Ralph Workflow — Example Config
# Copy to scripts/ralph/config.env and customize per-epic

# Target epic(s)
EPICS=fn-1-your-epic-slug

# App type: "native" (iOS/macOS Swift) or "web" (React, Next.js, etc.)
# Controls which quality gates run:
#   native → /ui-verify-xcode for visual verification, /qa methodology via simulator
#   web    → /browse for integration testing, /qa for QA verification
APP_TYPE=native

# Feature branch prefix (coordinator creates feature/<epic-slug> branches)
FEATURE_BRANCH_PREFIX=feature/

# Review gates (codex, rp, or none)
REQUIRE_PLAN_REVIEW=0
PLAN_REVIEW=codex
WORK_REVIEW=codex
COMPLETION_REVIEW=codex

# Codex settings
CODEX_SANDBOX=auto
FLOW_CODEX_EMBED_MAX_BYTES=500000

# Work settings
BRANCH_MODE=current
MAX_ITERATIONS=25
MAX_ATTEMPTS_PER_TASK=5

# Unattended mode
YOLO=1

# Rate limit handling — pause and retry (seconds)
RALPH_RATE_LIMIT_WAIT=300
